# Nexus environment template. Copy to `.env` and fill in REAL values for self-hosting.
# This file documents every variable consumed by the API and compose.prod.yaml.
# `.env` itself is gitignored — never commit real secrets.

# ---- PostgreSQL (compose.prod.yaml) ----
POSTGRES_DB=nexus
POSTGRES_DB_USER=nexus
# REQUIRED: set a strong password.
POSTGRES_DB_PASSWORD=change-me

# ---- API: datasource (only needed for non-compose / host runs; compose uses the above) ----
# NEXUS_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nexus
# NEXUS_DATASOURCE_USERNAME=nexus
# NEXUS_DATASOURCE_PASSWORD=change-me

# ---- API: Redis ----
# NEXUS_REDIS_URL=redis://localhost:6379

# ---- API: frontend / CORS ----
# Browser origin of the dashboard (panel redirects, OAuth post-logout).
NEXUS_FRONTEND_BASE_URL=http://localhost:3000
# Absolute base URL of the API as reachable from browsers (OAuth redirects, email links).
# NEXUS_API_EXTERNAL_BASE_URL=http://localhost:8080
# Additional origins allowed for cross-origin panel/end-user API calls (comma-separated).
# NEXUS_ALLOWED_DEV_ORIGINS=

# ---- API: session cookies (defaults are dev-friendly; prod profile sets secure=true) ----
# NEXUS_SESSION_TIMEOUT=7d
# NEXUS_SESSION_COOKIE_NAME=JSESSIONID
# NEXUS_SESSION_COOKIE_PATH=/
# NEXUS_SESSION_COOKIE_HTTP_ONLY=true
# NEXUS_SESSION_COOKIE_SAME_SITE=Lax
# NEXUS_SESSION_COOKIE_SECURE=true
# NEXUS_SESSION_COOKIE_MAX_AGE=7d

# ---- API: session-revocation resubmitter tuning (advanced; safe defaults) ----
# How often pending session-revocation events are replayed (e.g. after a Redis hiccup).
# NEXUS_SESSION_REVOCATION_RESUBMIT_INTERVAL=30s
# NEXUS_SESSION_REVOCATION_RESUBMIT_BATCH_SIZE=100
# NEXUS_SESSION_REVOCATION_RESUBMIT_MAX_IN_FLIGHT=1024
# NEXUS_SESSION_REVOCATION_RESUBMIT_MIN_AGE=10s

# ---- API: OAuth bootstrap client ----
# REQUIRED: a real secret (dev default 'changeme-local-dev' is rejected in prod).
NEXUS_OAUTH_BOOTSTRAP_CLIENT_SECRET=change-me
# NEXUS_OAUTH_BOOTSTRAP_REDIRECT_URI=http://127.0.0.1:8080/oauth2/bootstrap/callback

# ---- API: JWT signing keys ----
# REQUIRED: a real keystore (dev classpath:keystore/dev-jwk.p12 is rejected in prod).
# Mount it into the container and point this at the mounted path, e.g. file:/etc/nexus/jwt-keystore.p12
NEXUS_OAUTH_JWK_KEYSTORE_LOCATION=change-me
NEXUS_OAUTH_JWK_KEYSTORE_PASSWORD=change-me
NEXUS_OAUTH_JWK_KEY_ALIAS=nexus-key
NEXUS_OAUTH_JWK_KEY_PASSWORD=change-me

# ---- API: Vault master key (AES-256-GCM) ----
# REQUIRED: a real key (dev default is rejected in prod).
NEXUS_VAULT_MASTER_KEY=change-me

# ---- Web (Next.js dashboard) ----
# Browser-facing API base URL. NOTE: NEXT_PUBLIC_* is baked in at BUILD time.
# For a non-localhost deploy, rebuild the web image with the correct value here.
NEXT_PUBLIC_NEXUS_API_BASE_URL=http://localhost:8080
